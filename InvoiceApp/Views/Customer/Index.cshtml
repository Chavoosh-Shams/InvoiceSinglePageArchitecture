@{
    ViewBag.Title = "Customer";
}

<div>
    <!-- Add Btn -->
    <button class="btn btn-success"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
        Create New Customer +
    </button>

    <!-- Table -->
    <div class="mt-5">

        <p id="count" class="fw-bold"></p>

        <table class="table table-hover" style="border: 1px solid #f0f0f0 !important">

            <thead class="table-dark">

                <tr>
                    <th>
                        First Name
                    </th>
                    <th>
                        Last Name
                    </th>
                    <th>
                        Phone
                    </th>
                    <th>
                        City
                    </th>
                    <th>
                        Address
                    </th>
                    <th>
                        Actions
                    </th>
                </tr>

            </thead>

            <tbody class="table-body">
                <!-- Insert From JS -->
            </tbody>

        </table>

    </div>

    <!-- Create Modal -->
    <div class="modal fade" id="createModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">

                    <h5 class="modal-title">Create</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <!-- Body -->
                <div class="modal-body">

                    <div class="mb-3">

                        <label class="form-label">First Name</label>

                        <input type="text"
                               class="form-control"
                               id="firstNameInput"
                               placeholder="Enter first name">
                    </div>

                    <div class="mb-3">

                        <label class="form-label">Last Name</label>

                        <input type="text"
                               class="form-control"
                               id="lastNameInput"
                               placeholder="Enter last name">
                    </div>

                    <div class="mb-3">

                        <label class="form-label">Phone</label>

                        <input type="text"
                               class="form-control"
                               id="phoneNumberInput"
                               placeholder="Enter your phone number">
                    </div>

                    <div class="mb-3">

                        <label class="form-label">City</label>

                        <input type="text"
                               class="form-control"
                               id="cityInput"
                               placeholder="Enter City">
                    </div>

                    <div class="mb-3">

                        <label class="form-label">Address</label>

                        <input type="text"
                               class="form-control"
                               id="addressInput"
                               placeholder="Enter your Address">
                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="button"
                            class="btn btn-primary create-btn">
                        Save
                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- Update Modal -->
    <div class="modal fade" id="updateModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">Edite</h5>

                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <form>

                        <div class="mb-3">
                            <label class="form-label">FirstName</label>
                            <input type="text" class="form-control firstName-update-modal"
                                   placeholder="Edite first name">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">LastName</label>
                            <input type="text" class="form-control lastName-update-modal"
                                   placeholder="Edite last name">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Phone</label>
                            <input type="text" class="form-control phone-update-modal"
                                   placeholder="Edite Phone Number">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">City</label>
                            <input type="text" class="form-control city-update-modal"
                                   placeholder="Edite City">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Address</label>
                            <input type="text" class="form-control address-update-modal"
                                   placeholder="Edite Address">
                        </div>

                    </form>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button class="btn btn-success update-btn">
                        Save
                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">
                    Are you sure you want to delete this item?
                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="button" class="btn btn-danger remove-btn">
                        Remove
                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- Details Modal -->
    <div class="modal fade" id="detailsModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">

                    <h5 class="modal-title">Details</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <!-- Body -->
                <div class="modal-body">

                    <p><strong>Id:</strong> <span id="detailId"></span></p>

                    <p><strong>First Name:</strong> <span id="detailFirstName"></span></p>

                    <p><strong>Last Name:</strong> <span id="detailLastName"></span></p>

                    <p><strong>Phone:</strong> <span id="detailPhone"></span></p>

                    <p><strong>City:</strong> <span id="detailCity"></span></p>

                    <p><strong>Address:</strong> <span id="detailAddress"></span></p>

                </div>

                <!-- Footer -->
                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Close
                    </button>

                </div>

            </div>

        </div>

    </div>

</div>
<script src="~/js/customer.js"></script>