@{
    ViewBag.Title = "Product";
}

<div dir="ltr">

    <button class="btn btn-success"
            data-bs-toggle="modal"
            data-bs-target="#createModal">
        Create New Product +
    </button>


    <div class="mt-5">

        <p id="count" class="fw-bold"></p>

        <table class="table table-hover" style="border: 1px solid #f0f0f0 !important">

            <thead class="table-dark">

                <tr>

                    <th>
                        Product Name
                    </th>

                    <th>
                        Unit Price
                    </th>

                    <th>

                        Actions
                    </th>

                </tr>

            </thead>

            <tbody class="table-body">
                <!-- Insert From JS -->
            </tbody>

        </table>
    </div>


    <!-- Create Modal -->
    <div class="modal fade" id="createModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">

                    <h5 class="modal-title">Create</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <!-- Body -->
                <div class="modal-body">

                    <div class="mb-3">

                        <label class="form-label">ProductName</label>

                        <input type="text"
                               class="form-control"
                               id="productNameInput"
                               placeholder="Enter ProductName">
                    </div>

                    <div class="mb-3">

                        <label class="form-label">UnitPrice</label>

                        <input type="text"
                               class="form-control"
                               id="unitPriceInput"
                               placeholder="Enter UnitPrice">
                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="button"
                            class="btn btn-primary create-btn">
                        Save
                    </button>

                </div>

            </div>

        </div>

    </div>


    <!-- Update Modal -->
    <div class="modal fade" id="updateModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">Edite</h5>

                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <form>

                        <div class="mb-3">

                            <label class="form-label">ProductName</label>
                            <input type="text" class="form-control productName-update-modal"
                                   placeholder="Edite productName">

                        </div>

                        <div class="mb-3">

                            <label class="form-label">UnitPrice</label>
                            <input type="text" class="form-control unitPrice-update-modal"
                                   placeholder="Edite UnitPrice">

                        </div>

                    </form>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button class="btn btn-success update-btn">
                        Save
                    </button>

                </div>

            </div>
        </div>

    </div>


    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">
                    Are you sure you want to delete this item?
                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="button" class="btn btn-danger remove-btn">
                        Remove
                    </button>

                </div>

            </div>

        </div>

    </div>


    <!-- Details Modal -->
    <div class="modal fade" id="detailsModal" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">

                    <h5 class="modal-title">Details</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <!-- Body -->
                <div class="modal-body">

                    <p><strong>Id:</strong> <span id="detailId"></span></p>

                    <p><strong>ProductName:</strong> <span id="detailProductName"></span></p>

                    <p><strong>UnitPrice:</strong> <span id="detailUnitPrice"></span></p>

                </div>

                <!-- Footer -->
                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Close
                    </button>

                </div>

            </div>

        </div>

    </div>

</div>

<script src="~/js/product.js"></script>