@{
    ViewData["Title"] = "Invoice Management";
}

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-primary mb-1">
                Invoice List
            </h2>

            <small class="text-muted">
                View all registered invoices and orders
            </small>
        </div>

        <button class="btn btn-success shadow-sm">
            <a href="http://localhost:5013/OrderHeader"
               style="text-decoration:none;color:white">
                Create New Invoice
            </a>
        </button>

    </div>

    <!-- Search -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-4">
                    <input type="text"
                           class="form-control"
                           placeholder="Search by Customer Name">
                </div>

                <div class="col-md-4">
                    <input type="date"
                           class="form-control">
                </div>

                <div class="col-md-4">
                    <button class="btn btn-primary w-100">
                        Search
                    </button>
                </div>

            </div>

        </div>

    </div>

    <!-- Table -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center mb-0">

                    <thead class="table-primary">

                        <tr>
                            <th>No.</th>
                            <th>Invoice Number</th>
                            <th>Customer Name</th>
                            <th>Order Date</th>
                            <th>Shipping City</th>
                            <th>Shipping Address</th>
                            <th>Actions</th>
                        </tr>

                    </thead>

                    <tbody id="invoiceTableBody"></tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- Update Order Modal -->
<div class="modal fade" id="updateModal" tabindex="-1">

    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header bg-primary text-white">

                <h5 class="modal-title">
                    Edit Invoice
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <!-- Order Header -->
                <div class="row g-3 mb-4">

                    <input type="hidden"
                           id="updateOrderHeaderID" />

                    <div class="col-md-4">

                        <label class="form-label fw-bold">
                            Order Date
                        </label>

                        <input type="date"
                               class="form-control shadow-sm"
                               id="orderDate">

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Shipping City
                        </label>

                        <input type="text"
                               id="updateShipCity"
                               class="form-control">

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Shipping Address
                        </label>

                        <input type="text"
                               id="updateShipAddress"
                               class="form-control">

                    </div>

                </div>

                <!-- Customer -->
                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Customer Information
                    </h5>

                    <button type="button"
                            class="btn btn-primary px-4 shadow-sm Customer-Select-Btn">
                        Select Customer
                    </button>

                </div>

                <!-- Customer Info -->
                <div class="top-info-bar bg-light rounded-4 p-3 shadow-sm mb-4">

                    <div class="row text-center gy-3">

                        <div class="col-md-6">

                            <div class="p-2">

                                <div class="text-muted small mb-1">
                                    Customer
                                </div>

                                <strong class="customerNameDisplay fs-5">
                                    Not Selected
                                </strong>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="p-2">

                                <div class="text-muted small mb-1">
                                    Phone Number
                                </div>

                                <strong class="customerPhoneDisplay fs-5">
                                    ---
                                </strong>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- Product Selection -->
                <div class="mb-4">

                    <button class="btn btn-success shadow-sm Product-Select-Btn">
                        Select Products / Services
                    </button>

                </div>

                <!-- Invoice Items -->
                <div class="table-responsive">

                    <table class="table table-hover align-middle text-center">

                        <thead class="table-primary">

                            <tr>
                                <th>No.</th>
                                <th>Product Name</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total Price</th>
                                <th>Actions</th>
                            </tr>

                        </thead>

                        <tbody class="orderDetailBody">
                            <!-- Insert From JS -->
                        </tbody>

                    </table>

                </div>

            </div>

            <!-- Update Modal Btns -->
            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Close
                </button>

                <button class="btn btn-primary"
                        id="saveUpdateOrderBtn">
                    Save Changes
                </button>

            </div>

        </div>

    </div>

</div>

<!-- Info Order Modal -->
<div class="modal fade" id="infoModal" tabindex="-1">

    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header bg-primary text-white">

                <h5 class="modal-title">
                    Full Info Invoice
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <!-- Order Header -->
                <div class="row g-3 mb-4">

                    <input type="hidden"
                           id="updateOrderHeaderID" />

                    <div class="col-md-4">

                        <label class="form-label">
                            Order Date
                        </label>

                        <input type="text"
                               id="orderDateInfo"
                               class="form-control">

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Shipping City
                        </label>

                        <input type="text"
                               id="shipCityInfo"
                               class="form-control">

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Shipping Address
                        </label>

                        <input type="text"
                               id="shipAddressInfo"
                               class="form-control">
                    </div>

                </div>

                <!-- Customer -->
                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h5 class="fw-bold mb-0">
                        Customer Information
                    </h5>

                </div>

                <!-- Customer Info -->
                <div class="top-info-bar bg-light rounded-4 p-3 shadow-sm mb-4">

                    <div class="row text-center gy-3">

                        <div class="col-md-6">

                            <div class="p-2">

                                <div class="text-muted small mb-1">
                                    Customer
                                </div>

                                <strong class="customerNameDisplayInfo fs-5">
                                    Not Selected
                                </strong>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="p-2">

                                <div class="text-muted small mb-1">
                                    Phone Number
                                </div>

                                <strong class="customerPhoneDisplayInfo fs-5">
                                    ---
                                </strong>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- Invoice Items -->
                <div class="table-responsive">

                    <table class="table table-hover align-middle text-center">

                        <thead class="table-primary">

                            <tr>
                                <th>No.</th>
                                <th>Product Name</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total Price</th>
                            </tr>

                        </thead>

                        <tbody class="invoiceInfoBody">
                            <!-- Insert From JS -->
                        </tbody>

                    </table>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Close
                </button>

            </div>

        </div>

    </div>

</div>

<!-- Product Modal -->
<div class="modal fade"
     id="selectProductModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-light">

                <h5 class="modal-title">
                    Select Product / Service
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                </button>

            </div>

            <div class="modal-body">

                <input type="text"
                       class="form-control mb-3"
                       placeholder="Search product...">

                <div class="table-responsive"
                     style="max-height:400px;">

                    <table class="table table-hover align-middle text-center">

                        <thead class="table-light">

                            <tr>
                                <th>Product Name</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Action</th>
                            </tr>

                        </thead>

                        <tbody id="Products-Table-Body">
                            <!-- Insert From JS -->
                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Delete Invoice
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">
                Are you sure you want to delete this invoice?
            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-danger remove-btn">
                    Delete
                </button>

            </div>

        </div>

    </div>

</div>

<!-- Customer Modal -->
<div class="modal fade"
     id="customerModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Select Customer
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <input type="text"
                       class="form-control mb-3"
                       placeholder="Search Customer">

                <div class="table-responsive">

                    <table class="table table-hover">

                        <thead>

                            <tr>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Phone Number</th>
                                <th>City</th>
                                <th>Address</th>
                                <th>Select</th>
                            </tr>

                        </thead>

                        <tbody id="customerTableBody">


                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    body {
        background: #f4f6f9;
    }

    .table thead th {
        white-space: nowrap;
        padding: 16px;
        font-size: 15px;
    }

    .table tbody td {
        padding: 18px 12px;
        vertical-align: middle;
    }

    .card {
        border-radius: 20px;
    }

    .form-control {
        border-radius: 12px;
    }

    .btn {
        border-radius: 12px;
    }

    .table-hover tbody tr:hover {
        background-color: #f8fbff;
        transition: .2s;
    }

</style>

<script src="~/js/home.js"></script>